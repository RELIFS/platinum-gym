        {
            "id": "OVR-FAQ-MEMBERSHIP-001",
            "category": "Membership",
            "question": "info membership",
            "answer": "Membership Platinum Gym tersedia untuk umum dan mahasiswa. Untuk harga terbaru, sebutkan paket yang ingin dicek seperti Gym Umum, Gym Mahasiswa, Senam, atau Gym + Senam.",
            "source_sheet": "Knowledge Override"
        },
        {
            "id": "OVR-FAQ-MEMBERSHIP-002",
            "category": "Membership",
            "question": "cara daftar",
            "answer": "Pendaftaran member bisa dilakukan lewat menu Daftar Member di website. Isi data diri dengan benar, lalu ikuti instruksi verifikasi dan pembayaran yang tersedia.",
            "source_sheet": "Knowledge Override"
        },
        {
            "id": "OVR-FAQ-MEMBERSHIP-003",
            "category": "Membership",
            "question": "cara daftar member",
            "answer": "Untuk daftar member, buka menu Daftar Member, lengkapi data profil, lalu pilih paket membership yang sesuai. Jika ada kendala, admin bisa membantu lewat WhatsApp resmi.",
            "source_sheet": "Knowledge Override"
        },
        {
            "id": "OVR-FAQ-MEMBERSHIP-004",
            "category": "Membership",
            "question": "brp hrg gym umum",
            "answer": "Harga Gym Umum saat ini Rp249.000 untuk 30 hari. Jika ingin opsi durasi lebih panjang, cek juga paket Gym Umum 3 Bulan atau 6 Bulan.",
            "source_sheet": "Knowledge Override"
        },
        {
            "id": "OVR-FAQ-MEMBERSHIP-005",
            "category": "Membership",
            "question": "berapa harga paket gym",
            "answer": "Harga paket tergantung jenis membership yang dipilih. Sebutkan paketnya, misalnya Gym Umum, Gym Mahasiswa, Senam Umum, atau Gym + Senam, supaya Gymmi bisa jawab lebih tepat.",
            "source_sheet": "Knowledge Override"
        },
        {
            "id": "OVR-FAQ-MEMBERSHIP-006",
            "category": "Membership",
            "question": "apakah ada paket mahasiswa",
            "answer": "Ada paket mahasiswa dengan syarat sesuai data resmi Platinum Gym. Siapkan bukti mahasiswa jika diminta saat pendaftaran atau verifikasi profil.",
            "source_sheet": "Knowledge Override"
        },
        {
            "id": "OVR-FAQ-MEMBERSHIP-007",
            "category": "Membership",
            "question": "membership saya aktif atau tidak",
            "answer": "Member bisa cek status membership langsung di portal member pada halaman Membership atau Dashboard. Gymmi hanya menampilkan data akun yang sedang login.",
            "source_sheet": "Knowledge Override"
        },
        {
            "id": "OVR-FAQ-CLASS-001",
            "category": "Class",
            "question": "jadwal kelas",
            "answer": "Jadwal kelas tersedia di halaman Kelas untuk public dan Booking Kelas untuk member. Pilih kelas seperti Muaythai, Poundfit, Aerobic, atau Zumba untuk melihat hari dan jam yang aktif.",
            "source_sheet": "Knowledge Override"
        },
        {
            "id": "OVR-FAQ-CLASS-002",
            "category": "Class",
            "question": "jadwal kls",
            "answer": "Jadwal kelas bisa dicek di halaman Kelas. Untuk member, buka Booking Kelas agar bisa melihat jadwal aktif dan melakukan booking jika paketnya memenuhi syarat.",
            "source_sheet": "Knowledge Override"
        },
        {
            "id": "OVR-FAQ-CLASS-003",
            "category": "Class",
            "question": "booking muaythai gimana",
            "answer": "Booking Muaythai dilakukan dari portal member pada halaman Booking Kelas. Jika paket sesi Muaythai aktif dan masih ada sisa sesi, tombol booking akan tersedia pada jadwal yang sesuai.",
            "source_sheet": "Knowledge Override"
        },
        {
            "id": "OVR-FAQ-CLASS-004",
            "category": "Class",
            "question": "booking poundfit gimana",
            "answer": "Booking Poundfit dilakukan dari halaman Booking Kelas di portal member. Pastikan paket sesi Poundfit aktif dan pilih tanggal sesuai jadwal yang tersedia.",
            "source_sheet": "Knowledge Override"
        },
        {
            "id": "OVR-FAQ-CLASS-005",
            "category": "Class",
            "question": "kenapa tombol booking tidak bisa diklik",
            "answer": "Tombol Booking Kelas akan nonaktif jika paket yang dibutuhkan belum aktif, sesi habis, atau tanggal tidak sesuai jadwal. Cek halaman Membership untuk memastikan status paket.",
            "source_sheet": "Knowledge Override"
        },
        {
            "id": "OVR-FAQ-MUAYTHAI-PRIVATE-001",
            "category": "Class Terpisah",
            "question": "Apakah Muaythai privat atau bersama peserta lain?",
            "answer": "Muaythai tercatat sebagai kelas berjadwal dengan kapasitas terbatas. Jika ingin sesi privat atau latihan hanya dengan coach, konfirmasi ketersediaan ke admin Platinum Gym.",
            "source_sheet": "Knowledge Override"
        },
        {
            "id": "OVR-FAQ-MUAYTHAI-002",
